# BFF — copy to `.env` at repo root or export in your shell. Never commit real secrets.

PORT=3000

# PostgreSQL — optional; required for `POST /api/v1/bitacora/ingest`.
# Apply schema: psql "$DATABASE_URL" -f db/migrations/001_bitacora.sql
# DATABASE_URL=postgres://user:pass@localhost:5432/redesas_lite

# Comma-separated browser origins allowed to call the BFF (explicit allowlist).
# Unset defaults to http://localhost:5173. Empty string (CORS_ORIGINS=) denies all browser Origins.
CORS_ORIGINS=http://localhost:5173

# --- Phase 2 auth ---
# When `true`, the BFF skips the HTTP call to Pegasus (`GET ${PEGASUS_SITE}/api/login?auth=`).
# Required for local dev without a live Pegasus. Set to `false` in environments where Pegasus is reachable.
PEGASUS_AUTH_DISABLED=true

# Pegasus site base URL (no trailing slash required). Used when PEGASUS_AUTH_DISABLED is false.
# Real-auth mode requires BOTH:
# - PEGASUS_AUTH_DISABLED=false
# - PEGASUS_SITE set to a reachable Pegasus base URL
# PEGASUS_SITE=https://dev2.pegasusgateway.com

# --- Phase 4 Pegasus validation cache (HTTP path only; bypassed when PEGASUS_AUTH_DISABLED=true) ---
# PEGASUS_AUTH_CACHE_ENABLED=true
# PEGASUS_AUTH_CACHE_TTL_MS=300000
# PEGASUS_AUTH_CACHE_NEGATIVE_TTL_MS=60000
# PEGASUS_AUTH_CACHE_UNAVAILABLE_TTL_MS=5000
# PEGASUS_AUTH_CACHE_MAX_ENTRIES=5000
# PEGASUS_FETCH_TIMEOUT_MS=10000

# --- Phase 5 app-level authorization (optional allowlists) ---
# If BOTH are unset, any successfully authenticated Pegasus user can access the app.
# If one/both are set, users must match by Pegasus user id or group id to access protected routes.
# PEGASUS_ALLOWED_USER_IDS=123,456
# PEGASUS_ALLOWED_GROUP_IDS=10,ops-team
#
# Log a safe summary of inferred user/group fields from Pegasus /api/login JSON (no token, no raw body).
# Set to false to disable after validation.
# PEGASUS_PRINCIPAL_SUMMARY_LOG=true

# --- Phase 4 security headers ---
# Optional HSTS on the BFF only when always HTTPS (often prefer edge/CDN HSTS).
# ENABLE_HSTS_HEADER=false
# HSTS_MAX_AGE=31536000

# --- Phase 4 observability (optional stubs) ---
# OBSERVABILITY_CAPTURE_EXCEPTIONS=false
# OBSERVABILITY_CAPTURE_MESSAGES=false

# Optional: override canonical fixture path (defaults to fixtures/bitacora-canonical.json from repo root).
# FIXTURE_PATH=

# --- Phase 3 bitácora data (BFF only; browser never calls upstream) ---
# `fixture` (default if unset): serve normalized JSON from the canonical fixture file.
# `db`: read normalized row from PostgreSQL (`DATABASE_URL` required). Optional `GET /api/v1/bitacora?policy_incident=`.
# `integration`: GET raw upstream JSON, normalize to the same canonical shape, return it.
# BITACORA_DATA_MODE=fixture

# Required when BITACORA_DATA_MODE=integration — base URL of the upstream service (no trailing slash required).
# BITACORA_UPSTREAM_BASE_URL=https://upstream.example.com

# Path appended to BITACORA_UPSTREAM_BASE_URL (default /api/v1/bitacora/raw).
# BITACORA_UPSTREAM_PATH=/api/v1/bitacora/raw

# When integration mode fails (network, non-2xx, etc.), fall back to the canonical fixture (dev/local only).
# BITACORA_FIXTURE_ON_UPSTREAM_ERROR=false

# Comma-separated **parent** origins allowed to embed this app in an iframe (CSP `frame-ancestors`).
# Example: https://pegasus.example.com https://dev.pegasus.example.com
# Leave unset to omit the CSP header in dev (see README — set in staging/prod).
# FRAME_ANCESTORS=
